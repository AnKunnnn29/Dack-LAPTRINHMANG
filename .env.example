# Optional OpenAI report and agentic mode.
OPENAI_API_KEY=replace_with_your_openai_api_key
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional alert delivery.
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your_email@example.com
# SMTP_PASSWORD=your_app_password
# ALERT_EMAIL_FROM=your_email@example.com
# ALERT_EMAIL_TO=receiver@example.com

# Optional API protection. Leave blank for local-only classroom demo.
# API_KEY=replace_with_a_long_random_value
# ALLOW_NON_ALLOWLISTED_TARGETS=false
